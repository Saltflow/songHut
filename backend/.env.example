# SongHut 2.0 Backend — Environment Variables
# Copy to .env and fill in real values before running.

# ==== REQUIRED ====
SECRET_KEY=change-me-in-production-64-char-random-string-here
JWT_SECRET=change-me-in-production-64-char-random-string-here

# ==== DATABASE ====
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/songhut
# For SQLite (DEV ONLY, no PostgreSQL needed):
# DATABASE_URL=sqlite+aiosqlite:///./data/songhut.db

# ==== REDIS (optional, needed for Celery workers + rate limiting) ====
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ==== STORAGE ====
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data
# S3 (set STORAGE_BACKEND=s3 to enable):
# STORAGE_S3_BUCKET=songhut
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=

# ==== APPLICATION ====
DEBUG=true
CORS_ORIGINS=["*"]
MAX_FILE_SIZE_MB=200

# ==== JWT ====
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=30

# ==== ALGORITHM (Phase 3) ====
CREPE_MODEL_SIZE=tiny
SOUNDFONT_PATH=./assets/soundfont.sf2
MADMOM_MODEL=default
